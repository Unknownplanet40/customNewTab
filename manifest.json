{
  "manifest_version": 3,
  "name": "Capsss New Tab",
  "version": "1.0",
  "description": "This extension replaces the default new tab page with a custom one that I created",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_title": "Capsss New Tab",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "assets/images/icons/Icons-x48.png"
    }
  },
  "icons": {
    "48": "assets/images/icons/Icons-x48.png",
    "96": "assets/images/icons/Icons-x96.png",
    "144": "assets/images/icons/Icons-x144.png"
  },
  "host_permissions": [
    "https://suggestqueries.google.com/*"
  ],
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}